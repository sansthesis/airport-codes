// Base styling

*, *:after, *:before
  box-sizing: border-box

html
  font-size: 100%
  -webkit-text-size-adjust: none

body
  padding-top: $header-h
  background: black
  color: white

::-moz-selection
  background-color: cyan
  color: white

::selection
  background-color: cyan
  color: white

// Fade-in animation
{fadeInKeyframes}
